# 百度网盘下载工具配置文件

# ============================================
# 百度网盘认证（使用bypy）
# ============================================
# 本项目使用 bypy 库，采用 OAuth 认证方式
# 认证信息会自动保存在 ~/.bypy/ 目录中
#
# 配置方法：
# 1. 运行: pan-download --setup-bypy
# 2. 或运行: bypy info
# 3. 按提示完成OAuth认证
#
# 无需在配置文件中填写百度网盘相关参数

# ============================================
# SFTP服务器配置（必需，如需上传功能）
# ============================================
# 如果需要自动上传到SFTP服务器，请配置以下信息
SFTP_HOST=192.168.0.122
SFTP_PORT=22
SFTP_USERNAME=sftp01
SFTP_PASSWORD=123456
SFTP_REMOTE_PATH=/remote/path

# ============================================
# 性能配置（可选）
# ============================================
# 下载失败时的最大重试次数
MAX_RETRIES=3

# 连接超时时间（秒）
CONNECT_TIMEOUT=30

# 文件传输超时时间（秒）
TRANSFER_TIMEOUT=300

# ============================================
# 配置说明
# ============================================
# 1. 复制此文件为 .env
# 2. 填写实际的SFTP配置信息
# 3. bypy认证：运行 pan-download --setup-bypy
# 4. 测试配置：运行 pan-download --test-config
# 5. .env 文件包含敏感信息，不要提交到版本控制